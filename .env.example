# Copy to .env and adjust as needed.
POSTGRES_USER=recon
POSTGRES_PASSWORD=recon
POSTGRES_DB=recon

# Optional. If set, the `github` recon module will search public code for
# references to the target domain. A fine-grained PAT with read-only public
# access is sufficient.
GITHUB_TOKEN=

# Optional. If set, the `shodan` module will query passive DNS + host data
# from Shodan. Get one at https://account.shodan.io/ (free tier works for
# /dns/domain; host search needs a paid plan).
SHODAN_API_KEY=
